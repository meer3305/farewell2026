# Admin (server-side only — falls back to freshers2026 if not set)
ADMIN_PASSWORD=your-secure-admin-password

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only - never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Brevo Transactional Email API (key starts with xkeysib-)
# Get it from https://brevo.com > Settings > API Keys > Create a new key
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender email must be verified in Brevo (Settings > Senders)
# BREVO_SENDER_EMAIL=your-verified-email@example.com
